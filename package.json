{
  "name": "cpek",
  "version": "0.1.0",
  "private": true,
  "description": "CPEK — Gestão financeira multiunidade · multi-tenant (Vue 3 + Nuxt 3 · Supabase/PostgreSQL · Prisma)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:rls": "psql \"$DIRECT_URL\" -v cpek_app_password=\"'$CPEK_APP_DB_PASSWORD'\" -f prisma/rls/policies.sql",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.5.5",
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.4",
    "chart.js": "^4.5.1",
    "pinia": "^2.2.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.14.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.48.2",
    "@primevue/nuxt-module": "^4.5.5",
    "@types/node": "^20.16.13",
    "@typescript-eslint/parser": "^8.11.0",
    "@typescript-eslint/utils": "^8.11.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.13.0",
    "nuxt": "^3.13.2",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-primeui": "^0.6.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "vue-tsc": "^2.1.6"
  }
}
