# ============================================================================
# CPEK — variáveis de ambiente (EXEMPLO, sem segredos). Copie para .env (não
# .env.local — o Nuxt/Nitro em dev não carrega esse arquivo automaticamente).
# Ver README §1 e ARCHITECTURE §4.4. SUPABASE_SERVICE_ROLE_KEY nunca vai ao client.
# DIRECT_URL nunca é usada em runtime (só migrations/policies).
# ============================================================================

# ── Banco ───────────────────────────────────────────────────────────────────
# Runtime — Shared Pooler / Supavisor (papel cpek_app, SUBMETIDO ao RLS).
# pgbouncer=true desliga prepared statements (necessário no pooler).
#
# Formato: postgresql://<papel>.<PROJECT_REF>@aws-<N>-<região>.pooler.supabase.com:6543/postgres
# - usuário leva um PONTO + o ref do projeto (não é só "cpek_app").
# - <N> é o índice do nó do pooler (0, 1, 2…) — varia por projeto, não dá pra
#   adivinhar. Pegue a string exata em Supabase Dashboard → Connect → aba
#   "Transaction pooler" (não "Direct connection" — essa é IPv6-only e não
#   funciona a partir de serverless como Vercel, que não tem saída IPv6).
#
# connection_limit=5: cada withTenant() abre uma transação (1 conexão) e uma
# transação não compartilha conexão com outra — connection_limit=1 serializava
# TODA chamada concorrente (duas abas, dois usuários, dois handlers) na mesma
# conexão. 5 dá folga pra concorrência real sem abrir mão do teto por instância
# serverless (medido: 5 requests concorrentes caíram de ~4.6s pra ~1.7s).
DATABASE_URL="postgresql://cpek_app.CHANGE_ME_project_ref:CHANGE_ME@aws-N-CHANGE_ME_region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Migrations — conexão direta (papel postgres). NUNCA em runtime.
DIRECT_URL="postgresql://postgres:CHANGE_ME@db.<proj>.supabase.co:5432/postgres"

# Senha do papel de runtime cpek_app (usada por prisma/rls/policies.sql).
CPEK_APP_DB_PASSWORD="CHANGE_ME"

# ── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL="https://<proj>.supabase.co"
SUPABASE_ANON_KEY="CHANGE_ME_anon_key"
# SÓ no servidor — grava app_metadata { account_id, role } no signup/convite.
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME_service_role_key"
# Segredo JWT do projeto Supabase — OPCIONAL. Se definido, o middleware valida o
# token localmente (HS256). Se vazio, valida via API do Supabase (GET /auth/v1/user)
# usando a SUPABASE_ANON_KEY. Ver server/utils/authVerify.ts.
SUPABASE_JWT_SECRET=""

# ── Testes (opcional) ────────────────────────────────────────────────────────
# Banco descartável para o teste de isolamento RLS em matriz (ver tests/README.md).
# TEST_DATABASE_URL="postgresql://cpek_app:CHANGE_ME@localhost:6543/cpek_test?pgbouncer=true&connection_limit=1"
# TEST_DIRECT_URL="postgresql://postgres:CHANGE_ME@localhost:5432/cpek_test"
# E2E_BASE_URL="http://localhost:3000"
